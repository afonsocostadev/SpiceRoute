<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SpiceRoute</title>
    <script type="importmap"></script>
    <!-- <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/> -->
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/MVVM.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="flex justify-between p-4 m-4 ">
        <a asp-page="/Index" class="text-black no-underline">SpiceRoute</a>
        <div class="flex gap-4 items-center justify-center">
            <a asp-page="/Index">Home</a>
            <div class="w-10 h-10 bg-[#000] bg rounded-full bg-"></div>
            <component type="typeof(ThemeButton)" render-mode="ServerPrerendered"/>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - MVVM - <a asp-area="" asp-page="/Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<!--<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>-->
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>